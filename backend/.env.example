# ==============================================================================
# RETAILIQ - ENVIRONMENT CONFIGURATION
# ==============================================================================
# IMPORTANT: Never commit actual .env files containing production secrets.
# Copy this file to .env and fill in the values for local development.

# ── Core API ──────────────────────────────────────────────────────────────────
PROJECT_NAME="RetailIQ API"
API_V1_STR="/api/v1"
CORS_ORIGINS=["http://localhost:5173", "https://retailiq-frontend.vercel.app"]

# ── Database (PostGIS) ────────────────────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_USER=retailiq
POSTGRES_PASSWORD=retailiq_secret  # Change in production!
POSTGRES_DB=retailiq
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ── Security & Authentication ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=dev_secret_key_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Production Telemetry & Monitoring (Azure App Insights) ────────────────────
# Set this in production to enable OpenTelemetry tracking of API, DB, and Celery
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── Environment Specific Overrides ────────────────────────────────────────────
# DEV
# POSTGRES_SERVER=localhost
# REDIS_URL=redis://localhost:6379/0

# STAGING
# CORS_ORIGINS=["https://staging.retailiq.com"]
# DATABASE_URL=postgresql://staging-user:pass@staging-db-server.azure.com:5432/retailiq

# PROD
# CORS_ORIGINS=["https://retailiq.com", "https://app.retailiq.com"]
# DATABASE_URL=postgresql://prod-user:pass@prod-db-server.azure.com:5432/retailiq
